---
import Base from '../layouts/Base.astro';

const papers = [
  {
    title: 'Deep Clustering based Fair Outlier Detection',
    authors: ['Hanyu Song', 'Peizhao Li', 'Hongfu Liu'],
    venue: 'KDD 2021',
    links: [
      { label: 'arXiv', href: 'https://arxiv.org/abs/2106.05127' },
      { label: 'ACM', href: 'https://dl.acm.org/doi/10.1145/3447548.3467225' },
      {
        label: 'code',
        href: 'https://github.com/brandeis-machine-learning/FairOutlierDetection',
      },
    ],
  },
];
---

<Base title="Papers" description="Publications.">
  <h1>Papers</h1>
  <section style="margin-top: 2rem;">
    {
      papers.map((paper) => (
        <div class="paper">
          <p class="title" style="margin-bottom: 0.15rem;">{paper.title}</p>
          <p class="meta small">
            {paper.authors.map((a, i) => (
              <>
                {i > 0 && ', '}
                {a === 'Hanyu Song' ? <strong>{a}</strong> : a}
              </>
            ))}
            {' · '}
            {paper.venue}
          </p>
          <p class="links small">
            {paper.links.map((l) => (
              <a href={l.href}>{l.label}</a>
            ))}
          </p>
        </div>
      ))
    }
  </section>
</Base>
