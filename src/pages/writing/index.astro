---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<Base title="Writing" description="Essays and experiments.">
  <h1>Writing</h1>
  <section style="margin-top: 2rem;">
    {
      posts.length > 0 ? (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <span class="date mono">{fmt.format(post.data.date)}</span>
              <a href={`/writing/${post.slug}/`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">
          Nothing here yet — first post coming soon. There's an
          <a href="/rss.xml">RSS feed</a> if you'd like it delivered.
        </p>
      )
    }
  </section>
</Base>
